{
  "expo": {
    "name": "Vevhu Resources",
    "slug": "vevhu-field",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "vevhu-resources",
    "platforms": ["android", "web"],
    "icon": "./assets/images/icon.png",
    "android": {
      "package": "com.vevhu.fieldworker",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "backgroundColor": "#F3772D"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Vevhu Resources to record visit conversations for verification.",
          "enableBackgroundRecording": true,
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Vevhu Resources to take photos of stands and documents."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Vevhu Resources to track your location for field verification.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Vevhu Resources to access photos.",
          "cameraPermission": "Allow Vevhu Resources to take photos."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#F3772D"
        }
      ],
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 33,
            "buildArchs": ["arm64-v8a"],
            "enableMinifyInReleaseBuilds": true,
            "enableProguardInReleaseBuilds": true,
            "shrinkResources": true,
            "extraProguardRules": "-keep class com.powersync.** { *; }\n-keep class com.op.sqlite.** { *; }"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/f93d507d-89fd-44e0-9fda-8a0ec8d80768"
    },
    "runtimeVersion": "1.0.0",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f93d507d-89fd-44e0-9fda-8a0ec8d80768"
      }
    },
    "owner": "vevhu",
    "ios": {}
  }
}
